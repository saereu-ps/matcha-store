{
  "name": "@matcha/ui",
  "version": "0.1.0",
  "private": true,
  "description": "Matcha design system — immersive components, animations, 3D, theming, sound",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./theme.css": "./src/theme/tokens.css",
    "./tailwind-preset": "./src/theme/tailwind-preset.ts"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "clsx": "2.1.1",
    "framer-motion": "11.15.0",
    "howler": "2.2.4"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "tailwindcss": "^3.4.0"
  },
  "devDependencies": {
    "@matcha/config": "workspace:*",
    "@testing-library/react": "16.1.0",
    "@types/howler": "2.2.12",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "jsdom": "25.0.1",
    "next": "14.2.21",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tailwindcss": "3.4.17",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  }
}
