{
  "name": "matcha",
  "version": "0.1.0",
  "private": true,
  "description": "Premium matcha tea e-commerce platform — enterprise-grade microservices monorepo",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "codegen": "turbo run codegen",
    "dev": "turbo run dev",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "prepare": "husky",
    "new-service": "tsx scripts/new-service.ts",
    "migrate": "tsx scripts/migrate.ts",
    "seed": "tsx scripts/seed.ts",
    "reset-db": "tsx scripts/reset.ts"
  },
  "devDependencies": {
    "@commitlint/cli": "19.6.1",
    "@commitlint/config-conventional": "19.6.0",
    "husky": "9.1.7",
    "lint-staged": "15.4.3",
    "prettier": "3.8.3",
    "tsx": "4.22.4",
    "turbo": "2.9.16",
    "typescript": "5.7.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": ["eslint --fix", "prettier --write"],
    "*.{json,md,yaml,yml}": ["prettier --write"]
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.0.0"
  }
}
