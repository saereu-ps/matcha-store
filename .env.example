# ========================
# Matcha Platform — Environment Variables
# ========================

# Database (per service — replace SERVICE with product, user, etc.)
DATABASE_URL=postgresql://matcha:matcha_dev@localhost:5432/matcha_dev

# Redis
REDIS_URL=redis://localhost:6379

# Kafka
KAFKA_BROKERS=localhost:9092
SCHEMA_REGISTRY_URL=http://localhost:8081

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# Auth (JWT)
JWT_PUBLIC_KEY=
JWT_PRIVATE_KEY=
JWT_ISSUER=matcha-auth
JWT_AUDIENCE=matcha-platform
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# Telemetry
LOG_LEVEL=info
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=matcha-service

# External Services
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
SENDGRID_API_KEY=SG...
CLOUDINARY_URL=cloudinary://...
ALGOLIA_APP_ID=
ALGOLIA_API_KEY=
SEGMENT_WRITE_KEY=

# Application
NODE_ENV=development
PORT=3000
