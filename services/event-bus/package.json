{
  "name": "@matcha/event-bus",
  "version": "0.1.0",
  "private": true,
  "description": "Kafka event bus — producer, consumer, schema registry, dead letter queue",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
