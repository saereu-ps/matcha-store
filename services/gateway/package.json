{
  "name": "@matcha/gateway",
  "version": "0.1.0",
  "private": true,
  "description": "API Gateway — routing, rate limiting, auth verification, BFF aggregation",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@matcha/contracts": "workspace:*",
    "@matcha/shared-kernel": "workspace:*",
    "@matcha/telemetry": "workspace:*",
    "cors": "2.8.5",
    "express": "4.21.2",
    "express-rate-limit": "8.5.2",
    "helmet": "8.0.0",
    "http-proxy-middleware": "3.0.3",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@matcha/config": "workspace:*",
    "@types/cors": "2.8.17",
    "@types/express": "5.0.0",
    "@types/node": "^25.9.2",
    "tsx": "4.19.2",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  }
}
